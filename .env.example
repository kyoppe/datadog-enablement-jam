# ---------------------------------------------------------------------------
# Datadog Enablement Jam (DEJ) - environment example
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Datadog credentials (data plane only) ---------------------------------
# Get these from your Datadog org. Keep the API key secret (never commit .env).
DD_API_KEY=your-datadog-api-key
# Datadog site, e.g. datadoghq.com, datadoghq.eu, us3.datadoghq.com, ap1.datadoghq.com
DD_SITE=datadoghq.com

# --- Datadog APM tagging ---------------------------------------------------
# Shared environment tag for all DEJ telemetry (data plane + RUM).
DD_ENV=dej
# DD_VERSION is normally the git short SHA; overridden at build/run time.
DD_VERSION=dev

# --- DEJ session-scoped tags ----------------------------------------------
# These are injected into every demo-app service as APM tags:
#   dej_session, dej_module, dej_scenario
# For a real run, set DEJ_SESSION to the session_id created in the Admin UI,
# typically via: make scenario SESSION=<session_id>
DEJ_SESSION=local-dev
DEJ_MODULE=apm-service-page-basics
DEJ_SCENARIO=apm-slow-checkout-inventory

# --- Datadog Agent host (used by demo-app services) ------------------------
# Inside docker-compose the agent service is reachable as "datadog-agent".
DD_AGENT_HOST=datadog-agent
DD_TRACE_AGENT_PORT=8126

# --- Control plane frontend observability (RUM + Browser Logs) -------------
# These are exposed to the browser bundle (NEXT_PUBLIC_*). The client token is
# a public, embeddable RUM token (NOT the org API key). Create a Browser RUM
# application in Datadog and copy its applicationId / clientToken here.
# Set the real values in apps/web/.env.local (gitignored), not in .env.
NEXT_PUBLIC_DD_APPLICATION_ID=your-rum-application-id
NEXT_PUBLIC_DD_CLIENT_TOKEN=your-rum-client-token
NEXT_PUBLIC_DD_SITE=datadoghq.com
NEXT_PUBLIC_DD_ENV=dej
NEXT_PUBLIC_DD_SERVICE=dej-web
NEXT_PUBLIC_DD_VERSION=dev

# --- Control plane (DEJ web app) ------------------------------------------
# Base URL of the control plane. Locally this is the Next.js dev server.
# On EC2, the runner uses this to poll for pending sessions.
# Later this becomes your pages.dev URL.
DEJ_CONTROL_PLANE_URL=http://localhost:3000

# --- Optional: send DEJ score metrics/events to Datadog --------------------
# When true, the web app / helper forwards DEJ scoring to Datadog.
# Leave false for the core MVP.
DEJ_SEND_DATADOG_METRICS=false

# --- Scenario tuning -------------------------------------------------------
# Extra latency injected into inventory-service during the scenario (ms).
INVENTORY_EXTRA_LATENCY_MS=800
# Traffic generator request interval (seconds).
TRAFFIC_INTERVAL_SECONDS=1.0
