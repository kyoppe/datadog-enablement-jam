# Datadog Enablement Jam - control plane (Next.js) environment.
# Copy to .env.local and fill in. .env.local is gitignored.

# --- Frontend observability (RUM + Browser Logs) ---------------------------
# These are inlined into the browser bundle. The client token is a public,
# embeddable RUM token, NOT the org API key.
NEXT_PUBLIC_DD_APPLICATION_ID=
NEXT_PUBLIC_DD_CLIENT_TOKEN=
NEXT_PUBLIC_DD_SITE=datadoghq.com
NEXT_PUBLIC_DD_ENV=dej
NEXT_PUBLIC_DD_SERVICE=dej-web
NEXT_PUBLIC_DD_VERSION=dev

# --- Server-side Datadog secrets (control plane only) ----------------------
# NEVER prefix these with NEXT_PUBLIC_ (they must not reach the browser).
DD_API_KEY=
# App key needs the `user_access_manage` permission to provision users.
DD_APP_KEY=
DD_SITE=datadoghq.com
DD_ENV=dej
# Role id assigned to provisioned users (e.g. a read-only investigation role).
# Leave empty to create users without an explicit role.
DEJ_DATADOG_ROLE_ID=

# --- Test mode toggles -----------------------------------------------------
# Default (false) = test mode: no users are created and no metrics are sent;
# the intended actions are logged instead. Set to true to go live.
DEJ_SEND_METRICS=false
DEJ_PROVISION_USERS=false
